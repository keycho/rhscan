# rhscan indexer environment. copy to .env and fill in. secrets never enter git.

# the indexer's database connection. point this at supabase's DIRECT connection so
# the indexer gets its own dedicated backend connections, completely separate from
# the transaction pooler the web app uses — they must never share a budget (that
# starvation took the site down whenever the indexer ran). host
# db.<project-ref>.supabase.co, port 5432, username `postgres` (NOT the pooler's
# postgres.<project-ref>):
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.dhvnnchyfetwrkcyvflg.supabase.co:5432/postgres
# the indexer prefers INDEXER_DATABASE_URL when set, else DATABASE_URL, so you can
# keep them distinct if a single host ever runs both:
# INDEXER_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.dhvnnchyfetwrkcyvflg.supabase.co:5432/postgres
#
# FALLBACK — supabase direct connections are IPv6-only by default; if railway
# cannot reach the direct endpoint, use the SESSION pooler (port 5432) with a
# hard-capped PG_POOL_MAX=2 so the indexer holds at most 2 pooler connections and
# still cannot starve the site:
# DATABASE_URL=postgresql://postgres.dhvnnchyfetwrkcyvflg:[PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# production rpc. a paid provider with real concurrency. the public endpoint
# (https://rpc.mainnet.chain.robinhood.com) is rate limited, do not backfill it.
RPC_URL=https://your-paid-provider/robinhood-chain

# backfill | tail | both | tokens | prune | holders | live. default both.
# `live` is the production railway mode: tail + token metadata + partition
# maintainer, without the heavy backfill or holders replay (holder snapshots are
# built lazily by on-view hydration in the web app). keeps db/rpc load light while
# resolving fresh token names/symbols/decimals/total-supply.
MODE=both

# --- rolling window ---
# how many blocks of recent history to index. everything older resolves via live
# rpc (see the resolver). block-count sizing maps straight to disk (bytes ~
# blocks x head density) and does not drift with the chain's volatile block time.
# the default is ~100 GB at measured head density; see the readme sizing note.
WINDOW_BLOCKS=3000000

# --- partitioning ---
# blocks per range partition. the pruner drops whole partitions below the floor.
PARTITION_SIZE=500000
# partitions to keep created ahead of the head.
AHEAD_PARTITIONS=2
# how often the partition maintainer runs, in ms.
PARTITION_MAINTAIN_MS=60000

# --- pruner ---
# how often the window rolls forward (drops partitions below the floor).
PRUNE_INTERVAL_HOURS=24

# --- resolver ---
# max rows returned for an address transaction list.
ADDRESS_LIST_LIMIT=50

# --- token holders / hydration ---
# blocks per eth_getLogs chunk during hydration (shrinks on provider limits).
LOG_CHUNK=10000
# eagerly hydrate this many top tokens by windowed transfer count.
EAGER_TOP_N=25
# idle sleep when the hydration queue is empty, in ms.
HOLDERS_IDLE_MS=4000
# tokens compared per verify:balances run, and top holders per token.
VERIFY_TOKENS=5
VERIFY_TOP=20

# --- backfill tuning ---
# blocks per work-queue range.
RANGE_SIZE=200
# number of parallel range workers.
CONCURRENCY=50
# how often to print progress, in ms.
PROGRESS_MS=5000
# reclaim ranges left claimed by a crashed worker after this many minutes.
STALE_CLAIM_MIN=10
# attempts before a range is marked failed.
MAX_RANGE_ATTEMPTS=5

# --- tail tuning ---
# head poll interval, in ms.
POLL_MS=1000
# max blocks processed per poll while catching up.
TAIL_BATCH=100
# if the tail falls more than this many blocks behind the head, stop replaying the
# backlog and jump to the head instead — a fast chain outruns a cold/throttled
# tail, so grinding the backlog just keeps the head frozen. the skipped gap is left
# unindexed by design and can be backfilled separately.
TAIL_MAX_LAG=2000
# on a jump, resync this far behind the current head so the next poll indexes a
# small batch of recent blocks and the head shows "seconds ago" immediately.
TAIL_RESUME_BEHIND=25

# --- rpc transport ---
# ms viem waits before flushing a json-rpc batch.
BATCH_WAIT=20
# max json-rpc calls packed into one http batch. keep small: the provider meters
# per call, not per http request, so a huge batch is a burst that trips 429s.
BATCH_SIZE=20
# per-request timeout, in ms.
RPC_TIMEOUT_MS=30000
# retries per rpc call on rate-limit / transient errors before giving up.
MAX_RPC_ATTEMPTS=8

# --- rpc rate limit ---
# global token-bucket over ALL rpc lanes (one api key = one budget). counts
# json-rpc CALLS, not http requests, matching how alchemy meters (per compute
# unit). eth_getBlockReceipts is CU-heavy: measured on the pay-as-you-go endpoint
# over full minutes, ~40 calls/s (~20 blocks/s) sustains with ZERO 429s while ~60+
# draws a steady 429 stream, so the default is 40 — well under the nominal
# "300 req/s" (which only holds for cheap calls). raise this if you buy more CU/s.
RPC_RATE_LIMIT=40
# max burst of calls after idle. keep small so issuance stays smooth; a big burst
# spikes compute units and draws 429s.
RPC_RATE_BURST=10

# --- token metadata worker ---
# tokens resolved per multicall batch.
TOKENS_BATCH=50
# idle sleep when there is nothing to resolve, in ms.
TOKENS_IDLE_MS=5000

# --- db pool (indexer only) ---
# max postgres connections the indexer opens, shared across all its workers (one
# pool, not one per worker). while tailing it needs very few; keep it at 2 (3 max)
# so it holds a small, dedicated set of direct connections — and, on the session-
# pooler fallback, so it can never starve the site's pool. defaults to 10.
PG_POOL_MAX=2

# pino log level.
LOG_LEVEL=info

# ===========================================================================
# web explorer (next.js on vercel)
# ===========================================================================
# the web app shares this codebase but connects to a DIFFERENT database endpoint
# from the indexer, so the two never share a connection budget. serverless
# (vercel) notes:
#
#  - which DATABASE_URL goes where — DO NOT MIX THESE UP:
#      * vercel (web)      -> TRANSACTION pooler, port 6543, user postgres.<ref>:
#          postgresql://postgres.dhvnnchyfetwrkcyvflg:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres
#          DB_MODE=web  (or leave unset — a next.js runtime auto-detects to web)
#      * railway (indexer) -> DIRECT connection, port 5432, user postgres:
#          postgresql://postgres:[PASSWORD]@db.dhvnnchyfetwrkcyvflg.supabase.co:5432/postgres
#          DB_MODE=indexer  and  PG_POOL_MAX=2
#  - the transaction pooler runs pgbouncer in transaction mode: it does NOT support
#    prepared statements and multiplexes a backend per statement, so the web client
#    uses max:5 / prepare:false (or it fails with CONNECTION_CLOSED /
#    ECHECKOUTTIMEOUT). DB_MODE selects that profile vs the indexer's real pool.
#  - RPC_URL is used by the address page (live balance/nonce/code), the cold-path
#    resolver (data below the window), and the holders balance-drift check
#    (historical balanceOf via multicall3). a paid provider with archive access
#    to recent blocks is recommended; the drift check degrades to "could not
#    verify" if the state is unreadable.
#
# no coingecko key is needed; the eth price uses the public simple-price endpoint
# with 60s server-side caching.
