# rhscan indexer environment. copy to .env and fill in. secrets never enter git.

# supabase postgres connection string. use the direct (non-pooled) connection
# for backfill, the pool struggles with high concurrency.
DATABASE_URL=postgres://user:password@host:5432/postgres

# production rpc. a paid provider with real concurrency. the public endpoint
# (https://rpc.mainnet.chain.robinhood.com) is rate limited, do not backfill it.
RPC_URL=https://your-paid-provider/robinhood-chain

# backfill | tail | both | tokens | prune | holders. default both.
MODE=both

# --- rolling window ---
# how many blocks of recent history to index. everything older resolves via live
# rpc (see the resolver). block-count sizing maps straight to disk (bytes ~
# blocks x head density) and does not drift with the chain's volatile block time.
# the default is ~100 GB at measured head density; see the readme sizing note.
WINDOW_BLOCKS=3000000

# --- partitioning ---
# blocks per range partition. the pruner drops whole partitions below the floor.
PARTITION_SIZE=500000
# partitions to keep created ahead of the head.
AHEAD_PARTITIONS=2
# how often the partition maintainer runs, in ms.
PARTITION_MAINTAIN_MS=60000

# --- pruner ---
# how often the window rolls forward (drops partitions below the floor).
PRUNE_INTERVAL_HOURS=24

# --- resolver ---
# max rows returned for an address transaction list.
ADDRESS_LIST_LIMIT=50

# --- token holders / hydration ---
# blocks per eth_getLogs chunk during hydration (shrinks on provider limits).
LOG_CHUNK=10000
# eagerly hydrate this many top tokens by windowed transfer count.
EAGER_TOP_N=25
# idle sleep when the hydration queue is empty, in ms.
HOLDERS_IDLE_MS=4000
# tokens compared per verify:balances run, and top holders per token.
VERIFY_TOKENS=5
VERIFY_TOP=20

# --- backfill tuning ---
# blocks per work-queue range.
RANGE_SIZE=200
# number of parallel range workers.
CONCURRENCY=50
# how often to print progress, in ms.
PROGRESS_MS=5000
# reclaim ranges left claimed by a crashed worker after this many minutes.
STALE_CLAIM_MIN=10
# attempts before a range is marked failed.
MAX_RANGE_ATTEMPTS=5

# --- tail tuning ---
# head poll interval, in ms.
POLL_MS=1000
# max blocks processed per poll while catching up.
TAIL_BATCH=100

# --- rpc transport ---
# ms viem waits before flushing a json-rpc batch.
BATCH_WAIT=20
# max requests per json-rpc batch.
BATCH_SIZE=100
# per-request timeout, in ms.
RPC_TIMEOUT_MS=30000
# retries per rpc call on rate-limit / transient errors before giving up.
MAX_RPC_ATTEMPTS=8

# --- token metadata worker ---
# tokens resolved per multicall batch.
TOKENS_BATCH=50
# idle sleep when there is nothing to resolve, in ms.
TOKENS_IDLE_MS=5000

# --- db pool ---
# max postgres connections. defaults to CONCURRENCY + 6.
DB_POOL_MAX=56

# pino log level.
LOG_LEVEL=info
