{
  "name": "rhscan",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "indexer and database layer for a robinhood chain block explorer",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "migrate": "tsx src/migrate.ts",
    "backfill": "MODE=backfill tsx src/index.ts",
    "tail": "MODE=tail tsx src/index.ts",
    "prune": "MODE=prune tsx src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "echo no unit tests yet, transform decoding is validated against live rpc",
    "sample": "tsx src/sample.ts",
    "holders": "MODE=holders tsx src/index.ts",
    "verify:balances": "tsx src/verify.ts"
  },
  "dependencies": {
    "pino": "10.3.1",
    "postgres": "3.4.9",
    "viem": "2.55.2"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
